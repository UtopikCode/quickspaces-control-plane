# Database connection used by the control plane.
DATABASE_URL=mongodb://mongo:27017/quickspaces
DATABASE_NAME=quickspaces

# Execution provider for the control plane.
EXECUTION_PROVIDER=truenas

# HTTP listen address.
LISTEN_ADDR=:8080

# GitHub OAuth application settings.
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback

# Comma-separated list of admin users.
ADMIN_USERS=admin1,admin2