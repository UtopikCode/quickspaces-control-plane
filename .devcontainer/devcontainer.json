{
  "name": "QuickSpaces Control Plane",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ms-azuretools.vscode-docker",
        "mongodb.mongodb-vscode"
      ],
      "settings": {
        "mongodb.connections": [
          {
            "name": "QuickSpaces Dev Mongo",
            "connectionString": "mongodb://mongo:27017/quickspaces"
          }
        ]
      }
    }
  },
  "postCreateCommand": "go mod tidy",
  "postStartCommand": "bash .devcontainer/db-setup.sh",
  "runServices": ["mongo"],
  "shutdownAction": "stopCompose",
  "forwardPorts": [27017]
}
